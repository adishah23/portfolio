---
import Layout from '../layouts/Layout.astro';
import SheetHeader from '../components/SheetHeader.astro';
import { getExperience } from '../data/content';
const EXPERIENCE = await getExperience();
---
<Layout title="Experience — Aditya Shah" activeNav="experience">
  <div class="mx-auto max-w-7xl px-6 lg:px-10 pt-10 pb-20">
    <SheetHeader number="04" total="04" title="Experience" rev="A" />
    <div class="mt-4 mb-12">
      <div class="font-mono text-[11px] tracking-[0.25em] uppercase text-muted-foreground">04 positions · 6 years</div>
      <h1 class="font-display text-4xl md:text-5xl mt-2">From the FSAE paddock to the lab bench.</h1>
    </div>
    <div class="space-y-0">
      {EXPERIENCE.map((exp, i) => (
        <div class={`grid lg:grid-cols-12 gap-6 py-12 ${i > 0 ? 'border-t border-border' : ''}`}>
          <div class="lg:col-span-3 font-mono text-xs tracking-[0.15em] uppercase">
            <div class="text-muted-foreground mb-1">{exp.period}</div>
            <div class="text-muted-foreground">{exp.location}</div>
          </div>
          <div class="lg:col-span-9">
            <div class="font-display text-2xl md:text-3xl mb-1">{exp.role}</div>
            <div class="font-mono text-xs tracking-[0.15em] uppercase text-muted-foreground mb-5">{exp.org}</div>
            <ul class="space-y-3">
              {exp.bullets.map(b => (
                <li class="flex gap-3 text-sm font-mono leading-relaxed">
                  <span class="text-ember mt-1 flex-shrink-0">▸</span><span>{b}</span>
                </li>
              ))}
            </ul>
            <div class="mt-5 flex flex-wrap gap-2">
              {exp.tags.map(tag => (
                <span class="font-mono text-[11px] tracking-[0.2em] uppercase border border-border px-2 py-1 text-muted-foreground">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>
